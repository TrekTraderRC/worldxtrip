---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import CollectionWheel from '../components/CollectionWheel.jsx';
import AmorousSvgWorldMap from '../components/AmorousSvgWorldMap.jsx';
import 'flag-icons/css/flag-icons.min.css';
import {
  constellationItems,
  zodiacItems,
  getCollectionStats,
} from '../data/collectionData.js';
import {
  amorousCountries,
  amorousAtlasStats,
  getAmorousLevel,
  getAmorousLevelLabel,
} from '../data/amorousAtlas';

const user = Astro.locals.user;
const hasPaidAccess = Astro.locals.hasPaidAccess;

const constellationStats = getCollectionStats(constellationItems);
const zodiacStats = getCollectionStats(zodiacItems);

const amorousCountriesWithMeta = amorousCountries.map((country) => ({
  ...country,
  level: getAmorousLevel(country.count),
  label: getAmorousLevelLabel(country.count),
}));
---

<BaseLayout
  title="夜色图鉴 Collection - 夜色风月 | Amorous Planet | 世界游记"
  description="夜色图鉴收藏页，记录星座与生肖成就盘。"
  forceTheme="dark"
  pageClass="collection-layout"
>
  <Fragment slot="head">
    <style is:global>
      html,
      body {
        background: #05070d;
      }

      body.collection-layout,
      body.collection-layout main {
        background:
          radial-gradient(circle at 50% 0%, rgba(115, 220, 255, 0.08), transparent 24%),
          radial-gradient(circle at 18% 14%, rgba(158, 131, 255, 0.08), transparent 24%),
          radial-gradient(circle at 82% 14%, rgba(255, 115, 218, 0.06), transparent 20%),
          linear-gradient(180deg, #04060d 0%, #081020 58%, #05070d 100%) !important;
      }

      body.collection-layout {
        color: var(--text);
      }
      
      :root[data-theme='dark'] {
        --bg: #05070d;
        --bg-2: #0a1020;
        --bg-soft: #0a1020;

        --panel: rgba(14, 18, 32, 0.94);
        --panel-2: rgba(19, 25, 42, 0.94);
        --panel-strong: rgba(19, 25, 42, 0.94);

        --line: rgba(124, 156, 255, 0.14);
        --line-strong: rgba(115, 220, 255, 0.26);

        --text: #f7f3ff;
        --muted: #9aa6cb;
        --soft: #dbe3ff;

        --accent: #ff4fd8;
        --accent-2: #73dcff;
        --accent-soft: rgba(255, 79, 216, 0.14);

        --free-bg: rgba(106, 226, 255, 0.14);
        --free-text: #8beaff;

        --paid-bg: rgba(255, 79, 216, 0.14);
        --paid-text: #ff8ee7;

        --cyan: #73dcff;
        --blue: #7a96ff;
        --violet: #9e83ff;
        --pink: #ff73da;
        --gold: #f3d588;

        --hero-shadow: 0 24px 68px rgba(0, 0, 0, 0.42);
        --shadow: 0 24px 60px rgba(0, 0, 0, 0.34);
      }

      .theme-toggle {
        display: none !important;
      }

      .collection-page {
        color: var(--text);
        /* background:
          radial-gradient(circle at 50% 0%, rgba(115, 220, 255, 0.08), transparent 24%),
          radial-gradient(circle at 18% 14%, rgba(158, 131, 255, 0.08), transparent 24%),
          radial-gradient(circle at 82% 14%, rgba(255, 115, 218, 0.06), transparent 20%),
          linear-gradient(180deg, #04060d 0%, #081020 58%, #05070d 100%); */
      }

      .collection-page a {
        color: inherit;
      }

      .collection-page .wrap {
        max-width: 1360px;
        margin: 0 auto;
        padding: 28px 24px 90px;
      }

      .collection-page .hero-card,
      .collection-page .gate-card,
      .collection-page .placeholder-card {
        border-radius: 28px;
        border: 1px solid var(--line);
        background: var(--panel);
        box-shadow: var(--shadow);
      }

      .collection-page .hero-card {
        position: relative;
        overflow: hidden;
        padding: 34px 30px;
        margin-bottom: 24px;
      }

      .collection-page .hero-card::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
          radial-gradient(circle at top right, rgba(115, 220, 255, 0.10), transparent 24%),
          radial-gradient(circle at bottom left, rgba(158, 131, 255, 0.10), transparent 28%);
      }

      .collection-page .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border-radius: 999px;
        background: rgba(115, 220, 255, 0.08);
        color: var(--cyan);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .collection-page h1 {
        margin: 18px 0 14px;
        font-size: clamp(34px, 4.8vw, 68px);
        line-height: 1.02;
        letter-spacing: -0.05em;
      }

      .collection-page .hero-copy {
        max-width: 74ch;
        margin: 0;
        color: var(--muted);
        line-height: 1.9;
        font-size: 15px;
      }

      .collection-page .stats-grid {
        margin-top: 24px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
      }

      .collection-page .stat-card {
        border-radius: 24px;
        padding: 20px 20px 18px;
        background: linear-gradient(180deg, rgba(22, 28, 48, 0.94), rgba(16, 21, 38, 0.94));
        border: 1px solid rgba(124, 156, 255, 0.16);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.03),
          0 0 24px rgba(115, 220, 255, 0.03);
      }

      .collection-page .stat-kicker {
        color: var(--cyan);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 10px;
      }

      .collection-page .stat-head {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 10px;
      }

      .collection-page .stat-title {
        margin: 0;
        font-size: 28px;
        letter-spacing: -0.03em;
      }

      .collection-page .stat-main {
        font-size: 38px;
        font-weight: 800;
        line-height: 1;
        letter-spacing: -0.05em;
      }

      .collection-page .stat-sub {
        color: var(--muted);
        font-size: 14px;
        line-height: 1.75;
      }

      .collection-page .gate-card {
        padding: 32px 28px;
        margin-top: 24px;
        text-align: center;
      }

      .collection-page .gate-title {
        margin: 0 0 12px;
        font-size: 30px;
        letter-spacing: -0.03em;
      }

      .collection-page .gate-copy {
        max-width: 58ch;
        margin: 0 auto;
        color: var(--muted);
        line-height: 1.9;
      }

      .collection-page .gate-actions {
        display: flex;
        justify-content: center;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 24px;
      }

      .collection-page .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 48px;
        padding: 0 18px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 800;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }

      .collection-page .button:hover {
        transform: translateY(-1px);
      }

      .collection-page .button-primary {
        background: linear-gradient(90deg, var(--cyan), var(--pink));
        color: #081018;
        border: 0;
      }

      .collection-page .button-secondary {
        border: 1px solid rgba(255,255,255,0.12);
        color: var(--text);
        background: rgba(255,255,255,0.03);
      }

      .collection-page .wheels-grid {
        margin-top: 28px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 24px;
      }

      .collection-page .wheel-panel {
        border-radius: 30px;
        border: 1px solid var(--line);
        background:
          radial-gradient(circle at top center, rgba(115, 220, 255, 0.05), transparent 24%),
          linear-gradient(180deg, rgba(14,18,32,0.98), rgba(7,10,20,0.98));
        box-shadow: var(--shadow);
        padding: 22px 22px 26px;
      }

      .collection-page .wheel-panel-head {
        margin-bottom: 6px;
      }

      .collection-page .wheel-kicker {
        color: var(--cyan);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        opacity: 0.96;
      }

      .collection-page .wheel-title {
        margin: 8px 0 0;
        font-size: 22px;
        letter-spacing: -0.03em;
      }

      .collection-page .wheel-shell {
        position: relative;
        width: min(100%, 520px);
        aspect-ratio: 1 / 1;
        margin: 14px auto 0;
        border-radius: 50%;
        background:
          radial-gradient(circle at center, rgba(255,255,255,0.02), transparent 30%),
          radial-gradient(circle at center, rgba(115, 220, 255, 0.08), transparent 48%),
          radial-gradient(circle at 50% 48%, rgba(243, 213, 136, 0.05), transparent 18%),
          linear-gradient(180deg, rgba(15, 20, 36, 0.96), rgba(7, 10, 20, 0.98));
        overflow: hidden;
        box-shadow:
          inset 0 0 40px rgba(115, 220, 255, 0.05),
          0 0 30px rgba(115, 220, 255, 0.05);
      }

      .collection-page .wheel-glow {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
        filter: blur(20px);
      }

      .collection-page .wheel-glow-a {
        inset: 10% 10% auto auto;
        width: 120px;
        height: 120px;
        background: rgba(115, 220, 255, 0.08);
      }

      .collection-page .wheel-glow-b {
        inset: auto auto 12% 14%;
        width: 110px;
        height: 110px;
        background: rgba(158, 131, 255, 0.07);
      }

      .collection-page .wheel-ring {
        position: absolute;
        inset: 50%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
      }

      .collection-page .wheel-ring-outer {
        width: 96%;
        height: 96%;
        border: 1px solid rgba(136, 170, 255, 0.14);
        box-shadow:
          0 0 0 1px rgba(115, 220, 255, 0.04),
          0 0 24px rgba(115, 220, 255, 0.05);
      }

      .collection-page .wheel-ring-mid {
        width: 72%;
        height: 72%;
        border: 1px solid rgba(136, 170, 255, 0.12);
      }

      .collection-page .wheel-ring-inner {
        width: 34%;
        height: 34%;
        border: 1px solid rgba(136, 170, 255, 0.12);
      }

      .collection-page .wheel-center {
        position: absolute;
        inset: 50%;
        width: 30%;
        height: 30%;
        transform: translate(-50%, -50%);
        border-radius: 50%;
        border: 1px solid rgba(255,255,255,0.08);
        background:
          radial-gradient(circle at center, rgba(243, 213, 136, 0.22), rgba(243, 213, 136, 0.08) 42%, transparent 72%),
          linear-gradient(180deg, rgba(30,36,58,0.98), rgba(10,14,24,0.98));
        display: grid;
        place-items: center;
        text-align: center;
        padding: 14px;
        box-shadow:
          inset 0 0 24px rgba(243, 213, 136, 0.12),
          0 0 26px rgba(243, 213, 136, 0.10);
      }

      .collection-page .wheel-center-label {
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--soft);
      }

      .collection-page .wheel-center-value {
        margin-top: 6px;
        font-size: 28px;
        font-weight: 900;
        line-height: 1;
        letter-spacing: -0.04em;
        color: #fff4cf;
        text-shadow: 0 0 14px rgba(243, 213, 136, 0.14);
      }

      .collection-page .wheel-node {
        position: absolute;
        transform: translate(-50%, -50%);
        width: 106px;
        text-align: center;
        transition: transform 0.18s ease, filter 0.18s ease;
      }

      .collection-page .wheel-node:hover {
        transform: translate(-50%, -50%) scale(1.05);
        z-index: 3;
      }

      .collection-page .wheel-flame-wrap {
        display: flex;
        justify-content: center;
        margin-bottom: 7px;
      }

      .collection-page .wheel-flame {
        width: 18px;
        height: 34px;
        clip-path: polygon(50% 0%, 68% 18%, 82% 44%, 72% 74%, 50% 100%, 28% 74%, 18% 44%, 32% 18%);
        transition: all 0.25s ease;
      }

      .collection-page .wheel-flame.on {
        background:
          radial-gradient(circle at 50% 18%, rgba(255,255,255,0.98), transparent 20%),
          radial-gradient(circle at 50% 42%, rgba(182, 241, 255, 0.95), rgba(115, 220, 255, 0.68) 48%, rgba(115, 220, 255, 0.08) 75%, transparent 85%);
        box-shadow:
          0 0 12px rgba(180, 240, 255, 0.55),
          0 0 26px rgba(115, 220, 255, 0.28),
          0 0 46px rgba(115, 220, 255, 0.14);
        animation: flamePulse 2.2s ease-in-out infinite, flameFloat 3.4s ease-in-out infinite;
      }

      .collection-page .wheel-flame.off {
        background:
          linear-gradient(180deg, rgba(86, 100, 136, 0.22), rgba(36, 44, 68, 0.14));
        opacity: 0.55;
        filter: saturate(0.7);
      }

      .collection-page .wheel-node-card {
        border-radius: 14px;
        border: 1px solid rgba(120, 170, 255, 0.12);
        background:
          linear-gradient(180deg, rgba(14, 20, 36, 0.88), rgba(10, 14, 26, 0.94));
        padding: 8px 8px 10px;
        min-height: 78px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 4px;
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.03),
          inset 0 -10px 18px rgba(0,0,0,0.24);
      }

      .collection-page .wheel-node.unlocked .wheel-node-card {
        border-color: rgba(115, 220, 255, 0.20);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.04),
          inset 0 -10px 18px rgba(0,0,0,0.26),
          0 0 20px rgba(115, 220, 255, 0.06);
      }

      .collection-page .wheel-node-symbol {
        font-size: 22px;
        line-height: 1;
      }

      .collection-page .wheel-node-name {
        font-size: 13px;
        font-weight: 700;
        color: var(--text);
        line-height: 1.2;
      }

      .collection-page .wheel-node-count {
        font-variant-numeric: tabular-nums;
        font-size: 15px;
        font-weight: 900;
        letter-spacing: 0.04em;
      }

      .collection-page .wheel-node-count.on {
        color: #fff4cf;
        text-shadow: 0 0 10px rgba(255, 234, 170, 0.15);
      }

      .collection-page .wheel-node-count.off {
        color: #6a7395;
      }

      .collection-page .placeholder-grid {
        margin-top: 26px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .collection-page .placeholder-card {
        padding: 22px;
        background:
          linear-gradient(180deg, rgba(14,18,32,0.96), rgba(10,14,24,0.96));
      }

      .collection-page .placeholder-kicker {
        color: var(--cyan);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .collection-page .placeholder-title {
        margin: 10px 0 8px;
        font-size: 22px;
        letter-spacing: -0.03em;
      }

      .collection-page .placeholder-copy {
        color: var(--muted);
        line-height: 1.8;
        font-size: 14px;
      }

      .collection-page .amorous-atlas-card {
        margin-top: 26px;
        border-radius: 30px;
        border: 1px solid rgba(124, 156, 255, 0.16);
        background:
          radial-gradient(circle at 18% 12%, rgba(255, 115, 218, 0.14), transparent 28%),
          radial-gradient(circle at 82% 18%, rgba(115, 220, 255, 0.10), transparent 26%),
          linear-gradient(180deg, rgba(14,18,32,0.98), rgba(7,10,20,0.98));
        box-shadow: var(--shadow);
        padding: 28px;
        overflow: hidden;
        position: relative;
      }

      .collection-page .atlas-header {
        display: flex;
        justify-content: space-between;
        gap: 28px;
        align-items: flex-start;
        margin-bottom: 24px;
      }

      .collection-page .atlas-kicker {
        color: var(--cyan);
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        opacity: 0.96;
        margin-bottom: 10px;
      }

      .collection-page .atlas-header h2 {
        margin: 0 0 10px;
        font-size: 30px;
        letter-spacing: -0.04em;
        color: var(--text);
      }

      .collection-page .atlas-header p {
        max-width: 680px;
        margin: 0;
        color: var(--muted);
        line-height: 1.9;
        font-size: 14px;
      }

      .collection-page .atlas-stats {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        justify-content: flex-end;
      }

      .collection-page .atlas-stat {
        min-width: 112px;
        padding: 14px 16px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.045);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      .collection-page .atlas-stat span {
        display: block;
        color: var(--muted);
        font-size: 12px;
        margin-bottom: 6px;
      }

      .collection-page .atlas-stat strong {
        display: block;
        color: #fff4cf;
        font-size: 22px;
        line-height: 1;
        letter-spacing: -0.03em;
      }

      .collection-page .atlas-map-wrap {
        margin-bottom: 16px;
      }

      .collection-page .amorous-svg-map-shell {
        position: relative;
        min-height: 420px;
        border-radius: 26px;
        border: 1px solid rgba(124, 156, 255, 0.16);
        background:
          radial-gradient(circle at 50% 50%, rgba(243, 213, 136, 0.08), transparent 20%),
          radial-gradient(circle at 24% 36%, rgba(255, 115, 218, 0.10), transparent 20%),
          radial-gradient(circle at 74% 42%, rgba(115, 220, 255, 0.08), transparent 24%),
          linear-gradient(180deg, rgba(9, 12, 24, 0.96), rgba(5, 7, 15, 0.98));
        overflow: hidden;
        padding: 22px;
      }

      .collection-page .amorous-svg-map-shell::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 44px 44px;
        pointer-events: none;
        mask-image: radial-gradient(circle at center, black, transparent 78%);
      }

      .collection-page .amorous-svg-map-canvas {
        position: relative;
        z-index: 2;
        width: 100%;
        height: 420px;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .collection-page .amorous-world-svg {
        width: 100%;
        height: 100%;
        max-height: 420px;
        display: block;
      }

      .collection-page .amorous-world-svg path,
      .collection-page .amorous-world-svg polygon,
      .collection-page .amorous-world-svg g {
        outline: none;
      }

      .collection-page .amorous-map-tooltip {
        position: fixed;
        z-index: 999;
        max-width: 240px;
        pointer-events: none;
        padding: 12px 14px;
        border-radius: 16px;
        border: 1px solid rgba(124, 156, 255, 0.18);
        background: rgba(10, 14, 24, 0.96);
        box-shadow: 0 18px 36px rgba(0, 0, 0, 0.28);
        color: var(--text);
      }

      .collection-page .tooltip-code {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 24px;
        padding: 0 8px;
        border-radius: 999px;
        background: rgba(115, 220, 255, 0.08);
        color: var(--cyan);
        font-size: 11px;
        font-weight: 900;
        margin-bottom: 8px;
      }

      .collection-page .tooltip-title {
        font-size: 14px;
        font-weight: 800;
        line-height: 1.4;
        margin-bottom: 4px;
      }

      .collection-page .tooltip-meta {
        font-size: 12px;
        color: #fff4cf;
        margin-bottom: 6px;
      }

      .collection-page .tooltip-note {
        font-size: 12px;
        line-height: 1.6;
        color: var(--muted);
      }

      .collection-page .atlas-legend {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        align-items: center;
        color: var(--muted);
        font-size: 12px;
        margin-bottom: 22px;
      }

      .collection-page .atlas-legend span {
        display: inline-flex;
        gap: 6px;
        align-items: center;
      }

      .collection-page .atlas-legend i {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        display: inline-block;
      }

      .collection-page .atlas-legend i.level-0 {
        background: rgba(255, 255, 255, 0.12);
      }

      .collection-page .atlas-legend i.level-1 {
        background: rgba(158, 131, 255, 0.42);
      }

      .collection-page .atlas-legend i.level-2 {
        background: rgba(255, 115, 218, 0.50);
      }

      .collection-page .atlas-legend i.level-3 {
        background: rgba(255, 79, 216, 0.70);
      }

      .collection-page .atlas-legend i.level-4 {
        background: rgba(243, 213, 136, 0.94);
      }

      .collection-page .amorous-country-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 10px;
      }

      .collection-page .amorous-country-card {
        position: relative;
        min-height: 88px;
        padding: 11px 12px;
        border-radius: 16px;
        background:
          radial-gradient(circle at 86% 78%, rgba(255, 255, 255, 0.075), transparent 32%),
          linear-gradient(180deg, rgba(22, 28, 48, 0.78), rgba(16, 21, 38, 0.88));
        border: 1px solid rgba(124, 156, 255, 0.14);
        overflow: hidden;
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.03),
          0 0 16px rgba(115, 220, 255, 0.025);
      }

      .collection-page .country-card-top {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 8px;
        margin-bottom: 10px;
      }

      .collection-page .country-code {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 36px;
        height: 22px;
        padding: 0 8px;
        border-radius: 999px;
        background: rgba(115, 220, 255, 0.08);
        color: var(--cyan);
        font-size: 11px;
        font-weight: 900;
        line-height: 1;
      }

      .collection-page .country-count {
        text-align: right;
        flex: 0 0 auto;
        position: relative;
        z-index: 2;
      }

      .collection-page .country-count strong {
        display: block;
        color: #fff4cf;
        font-size: 22px;
        line-height: 0.9;
        letter-spacing: -0.05em;
      }

      .collection-page .country-count span {
        display: block;
        color: var(--muted);
        font-size: 10px;
        margin-top: 4px;
        white-space: nowrap;
      }

      .collection-page .country-name-block {
        position: relative;
        z-index: 2;
        padding-right: 30px;
      }

      .collection-page .country-name-block h3 {
        margin: 0 0 4px;
        color: var(--text);
        font-size: 15px;
        line-height: 1.15;
        letter-spacing: -0.02em;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .collection-page .country-name-block p {
        margin: 0;
        color: var(--muted);
        font-size: 11px;
        line-height: 1.2;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .collection-page .country-flag {
        position: absolute;
        right: 11px;
        bottom: 10px;
        width: 28px;
        height: 20px;
        border-radius: 4px;
        opacity: 0.95;
        box-shadow:
          0 0 0 1px rgba(255,255,255,0.10),
          0 8px 18px rgba(0,0,0,0.22);
        transform: none;
      }

      .collection-page .amorous-country-card.level-4 {
        border-color: rgba(243, 213, 136, 0.36);
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.03),
          0 0 26px rgba(243, 213, 136, 0.08);
      }

      .collection-page .amorous-country-card.level-3 {
        border-color: rgba(255, 79, 216, 0.28);
      }

      .collection-page .amorous-country-card.level-2 {
        border-color: rgba(158, 131, 255, 0.22);
      }

      .collection-page .amorous-country-card.level-1 {
        border-color: rgba(122, 150, 255, 0.18);
      }

      @keyframes flamePulse {
        0%, 100% {
          transform: scale(1);
          opacity: 0.92;
        }
        50% {
          transform: scale(1.08);
          opacity: 1;
        }
      }

      @keyframes flameFloat {
        0%, 100% {
          transform: translateY(0px) scale(1);
        }
        50% {
          transform: translateY(-2px) scale(1.04);
        }
      }

      @media (max-width: 1120px) {
        .collection-page .wheels-grid,
        .collection-page .placeholder-grid,
        .collection-page .stats-grid {
          grid-template-columns: 1fr;
        }

        .collection-page .atlas-header {
          flex-direction: column;
        }

        .collection-page .atlas-stats {
          justify-content: flex-start;
        }
      }

      @media (max-width: 720px) {
        .collection-page .wrap {
          padding: 22px 16px 64px;
        }

        .collection-page .hero-card,
        .collection-page .gate-card,
        .collection-page .placeholder-card,
        .collection-page .wheel-panel {
          border-radius: 22px;
        }

        .collection-page .hero-card,
        .collection-page .gate-card {
          padding: 22px 18px;
        }

        .collection-page .wheel-panel {
          padding: 18px 18px 22px;
        }

        .collection-page .wheel-shell {
          width: min(100%, 420px);
        }

        .collection-page .wheel-node {
          width: 82px;
        }

        .collection-page .wheel-node-card {
          min-height: 66px;
          padding: 7px 6px 8px;
        }

        .collection-page .wheel-node-symbol {
          font-size: 16px;
        }

        .collection-page .wheel-node-name {
          font-size: 11px;
        }

        .collection-page .wheel-node-count {
          font-size: 12px;
        }

        .collection-page .wheel-center-value {
          font-size: 20px;
        }

        .collection-page .stat-head {
          align-items: center;
        }

        .collection-page .stat-title {
          font-size: 24px;
        }

        .collection-page .stat-main {
          font-size: 30px;
        }

        .collection-page .amorous-svg-map-shell {
          min-height: 320px;
          padding: 14px;
        }

        .collection-page .amorous-svg-map-canvas {
          height: 320px;
        }

        .collection-page .amorous-world-svg {
          max-height: 320px;
        }

        .collection-page .amorous-country-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 9px;
        }

        .collection-page .amorous-country-card {
          min-height: 84px;
          padding: 10px;
        }

        .collection-page .country-name-block h3 {
          font-size: 14px;
        }

        .collection-page .country-name-block p {
          font-size: 10px;
        }

        .collection-page .country-count strong {
          font-size: 20px;
        }

        .collection-page .country-flag {
          width: 24px;
          height: 17px;
        }
      }
    </style>
  </Fragment>

  <div class="collection-page">
    <div class="wrap">
      <section class="hero-card">
        <span class="eyebrow">夜色图鉴 / Collection</span>
        <h1>命盘点火，缘分留痕。</h1>
        <p class="hero-copy">
          有些相遇不会久留，但可以被记录、被命名、被点亮。
          本轮图鉴先记录十二星座与十二生肖。
          每出现一次，就在对应宫位留下一个计数；每解锁一种，就点燃一簇火。
        </p>

        <div class="stats-grid">
          <article class="stat-card">
            <div class="stat-kicker">Constellation</div>
            <div class="stat-head">
              <h2 class="stat-title">星座图鉴</h2>
              <div class="stat-main">{constellationStats.unlockedKinds} / 12</div>
            </div>
            <div class="stat-sub">本轮累计记录：{constellationStats.totalCount} 次</div>
          </article>

          <article class="stat-card">
            <div class="stat-kicker">Chinese Zodiac</div>
            <div class="stat-head">
              <h2 class="stat-title">生肖图鉴</h2>
              <div class="stat-main">{zodiacStats.unlockedKinds} / 12</div>
            </div>
            <div class="stat-sub">本轮累计记录：{zodiacStats.totalCount} 次</div>
          </article>
        </div>
      </section>

      {!user ? (
        <section class="gate-card">
          <h2 class="gate-title">请先登录以查看图鉴内容</h2>
          <p class="gate-copy">
            夜色图鉴属于会员收藏页。登录后可继续查看账户状态，并解锁后续付费内容。
          </p>
          <div class="gate-actions">
            <a class="button button-primary" href="/login">前往登录</a>
            <a class="button button-secondary" href="/">返回首页</a>
          </div>
        </section>
      ) : !hasPaidAccess ? (
        <section class="gate-card">
          <h2 class="gate-title">该内容为付费收藏内容</h2>
          <p class="gate-copy">
            你已登录，但当前没有有效付费权限。订阅后即可解锁完整图鉴页面与后续收藏内容。
          </p>
          <div class="gate-actions">
            <a class="button button-primary" href="/pricing">查看订阅方案</a>
            <a class="button button-secondary" href="/account">我的账户</a>
          </div>
        </section>
      ) : (
        <>
          <section class="wheels-grid">
            <CollectionWheel
              client:load
              title="十二星座"
              subtitle="Constellation Wheel"
              items={constellationItems}
              centerTop="已解锁 / 累计"
              centerBottom={`${constellationStats.unlockedKinds}/12 (${constellationStats.totalCount})`}
              mode="constellation"
            />

            <CollectionWheel
              client:load
              title="十二生肖"
              subtitle="Zodiac Wheel"
              items={zodiacItems}
              centerTop="已解锁 / 累计"
              centerBottom={`${zodiacStats.unlockedKinds}/12 (${zodiacStats.totalCount})`}
              mode="zodiac"
            />
          </section>

          <section class="amorous-atlas-card">
            <div class="atlas-header">
              <div>
                <div class="atlas-kicker">AMOROUS ATLAS</div>
                <h2>万国图鉴</h2>
                <p>
                  点亮的不是行程，而是相逢。以国籍为经纬，记录那些曾经照亮夜色的人间记忆。
                </p>
              </div>

              <div class="atlas-stats">
                <div class="atlas-stat">
                  <span>已点亮国家</span>
                  <strong>{amorousAtlasStats.litCountries}</strong>
                </div>

                <div class="atlas-stat">
                  <span>相逢总数</span>
                  <strong>{amorousAtlasStats.totalEncounters}</strong>
                </div>

                <div class="atlas-stat">
                  <span>最高热度</span>
                  <strong>{amorousAtlasStats.topCountry?.nameEn}</strong>
                </div>
              </div>
            </div>

            <div class="atlas-map-wrap">
              <AmorousSvgWorldMap client:load countries={amorousCountriesWithMeta} />
            </div>

            <div class="atlas-legend">
              <span><i class="level-0"></i>未遇</span>
              <span><i class="level-1"></i>初见</span>
              <span><i class="level-2"></i>有缘</span>
              <span><i class="level-3"></i>多情</span>
              <span><i class="level-4"></i>长夜</span>
            </div>

            <div class="amorous-country-grid compact">
              {amorousCountriesWithMeta
                .filter((country) => country.count > 0)
                .sort((a, b) => b.count - a.count)
                .map((country) => (
                  <article class={`amorous-country-card compact level-${country.level}`}>
                    <div class="country-card-top">
                      <span class="country-code">{country.code}</span>

                      <div class="country-count">
                        <strong>{country.count}</strong>
                        <span>{country.label}</span>
                      </div>
                    </div>

                    <div class="country-name-block">
                      <h3>{country.nameZh}</h3>
                      <p>{country.nameEn}</p>
                    </div>

                    <span
                      class={`country-flag fi fi-${country.code.toLowerCase()}`}
                      aria-hidden="true"
                    ></span>
                  </article>
                ))}
            </div>
          </section>

          <section class="placeholder-grid">
            <article class="placeholder-card">
              <div class="placeholder-kicker">Coming Soon</div>
              <h3 class="placeholder-title">城市图鉴</h3>
              <p class="placeholder-copy">
                建设中...
              </p>
            </article>

            <article class="placeholder-card">
              <div class="placeholder-kicker">Coming Soon</div>
              <h3 class="placeholder-title">特殊成就</h3>
              <p class="placeholder-copy">
                建设中...
              </p>
            </article>

            <article class="placeholder-card">
              <div class="placeholder-kicker">Coming Soon</div>
              <h3 class="placeholder-title">更多图鉴</h3>
              <p class="placeholder-copy">
                预留中...
              </p>
            </article>
          </section>
        </>
      )}
    </div>
  </div>
</BaseLayout>