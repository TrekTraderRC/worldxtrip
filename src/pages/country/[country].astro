---
import { getCollection, render } from 'astro:content';
import 'flag-icons/css/flag-icons.min.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { countries } from '../../data/countries';

export const prerender = false;

const { country } = Astro.params;

const allPosts = await getCollection('travel');

const countryPosts = allPosts
  .filter(
    (post) => post.data.country.toLowerCase().replaceAll(' ', '-') === country
  )
  .sort((a, b) => a.data.order - b.data.order);

if (countryPosts.length === 0) {
  return new Response('Not found', { status: 404 });
}

const countryConfig = country
  ? countries[country as keyof typeof countries]
  : undefined;

const countryName = countryConfig?.name ?? countryPosts[0].data.country;
const countryCode = countryPosts[0].data.countryCode;
const region = countryConfig?.region ?? countryPosts[0].data.region;
const countryDescription = countryConfig?.description ?? '这里收录这个国家/地区下的旅行记录与城市片段。';
const icon = countryPosts[0]?.data.icon;

const currentUser = Astro.locals.user;
const hasPaidAccess = Astro.locals.hasPaidAccess;

const renderedPosts = await Promise.all(
  countryPosts.map(async (post) => {
    const rendered = await render(post);
    return {
      post,
      Content: rendered.Content,
    };
  })
);

const freeCount = countryPosts.filter((post) => post.data.tier === 'free').length;
const paidCount = countryPosts.filter((post) => post.data.tier === 'paid').length;
---

<BaseLayout
  title={`${countryName} - 世界游记`}
  description={`${countryName} 的夜生活游记、长文记录与付费内容归档。`}
>
  <Fragment slot="head">
    <style>
      :root {
        --bg: #f8f3f8;
        --bg-soft: #fcf7fc;
        --panel: rgba(255, 255, 255, 0.7);
        --panel-strong: rgba(255, 255, 255, 0.88);

        --text: #20171f;
        --muted: #7d6879;

        --line: rgba(80, 42, 72, 0.10);
        --line-strong: rgba(80, 42, 72, 0.16);

        --accent: #b05c8e;
        --accent-2: #d88cc8;
        --accent-soft: rgba(176, 92, 142, 0.10);

        --free-bg: #f3e8f7;
        --free-text: #7a3d86;

        --paid-bg: #fde7f1;
        --paid-text: #b13b73;

        --shadow: 0 14px 36px rgba(113, 61, 104, 0.08);
        --hero-shadow: 0 20px 60px rgba(113, 61, 104, 0.10);
      }

      :root[data-theme='dark'] {
        --bg: #0c0b14;
        --bg-soft: #131222;
        --panel: rgba(18, 20, 34, 0.78);
        --panel-strong: rgba(24, 27, 46, 0.92);

        --text: #f7f2ff;
        --muted: #b8a8d6;

        --line: rgba(120, 104, 255, 0.18);
        --line-strong: rgba(255, 79, 216, 0.26);

        --accent: #ff4fd8;
        --accent-2: #6ae2ff;
        --accent-soft: rgba(255, 79, 216, 0.14);

        --free-bg: rgba(106, 226, 255, 0.14);
        --free-text: #8beaff;

        --paid-bg: rgba(255, 79, 216, 0.14);
        --paid-text: #ff8ee7;

        --shadow: 0 16px 40px rgba(0, 0, 0, 0.28);
        --hero-shadow: 0 24px 68px rgba(0, 0, 0, 0.42);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Inter, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Sans SC", system-ui, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(255, 79, 216, 0.08), transparent 30%),
          radial-gradient(circle at top right, rgba(106, 226, 255, 0.08), transparent 26%),
          radial-gradient(circle at bottom center, rgba(120, 104, 255, 0.08), transparent 36%),
          var(--bg);
      }

      a {
        color: inherit;
      }

      .container {
        max-width: 1240px;
        margin: 0 auto;
        padding: 24px 24px 88px;
      }

      .hero {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border-radius: 30px;
        padding: 34px;
        box-shadow: var(--hero-shadow);
        margin-bottom: 26px;
      }

      .hero-top {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 24px;
        flex-wrap: wrap;
      }

      .hero-copy {
        max-width: 760px;
      }

      .hero-kicker {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      h1 {
        margin: 16px 0 12px;
        font-size: clamp(40px, 6vw, 66px);
        line-height: 0.98;
        letter-spacing: -0.05em;
      }

      .hero-subtitle {
        font-size: 17px;
        line-height: 1.85;
        color: var(--muted);
        max-width: 62ch;
        margin: 0;
      }

      .hero-stats {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 24px;
      }

      .hero-stat {
        padding: 10px 14px;
        border-radius: 999px;
        background: var(--panel-strong);
        border: 1px solid var(--line);
        font-size: 13px;
        color: var(--muted);
      }

      .filter-bar {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .filter-btn {
        border: 1px solid var(--line-strong);
        background: var(--panel-strong);
        color: var(--text);
        border-radius: 999px;
        padding: 10px 16px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.18s ease, background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
      }

      .filter-btn:hover {
        transform: translateY(-1px);
      }

      .filter-btn.active {
        background: var(--text);
        color: var(--bg);
        border-color: transparent;
        box-shadow: 0 0 0 1px rgba(255, 79, 216, 0.16), 0 0 18px rgba(255, 79, 216, 0.10);
      }

      .layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 290px;
        gap: 26px;
        align-items: start;
      }

      .main-column {
        display: grid;
        gap: 20px;
      }

      .post-card,
      .sidebar {
        border: 1px solid var(--line);
        background: var(--panel);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: var(--shadow);
      }

      .post-card {
        border-radius: 26px;
        padding: 18px;
        overflow: hidden;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }

      .post-card:hover {
        transform: translateY(-2px);
        border-color: var(--line-strong);
        box-shadow: 0 0 0 1px rgba(255, 79, 216, 0.12), 0 10px 30px rgba(106, 226, 255, 0.06);
      }

      .post-summary {
        cursor: pointer;
        list-style: none;
      }

      .post-summary::-webkit-details-marker {
        display: none;
      }

      .post-header {
        display: grid;
        grid-template-columns: 270px minmax(0, 1fr);
        gap: 22px;
        align-items: start;
      }

      .post-cover {
        width: 100%;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        border-radius: 20px;
        background: rgba(0, 0, 0, 0.06);
      }

      .post-cover img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .post-cover.placeholder {
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--muted);
        font-size: 13px;
        border: 1px dashed var(--line-strong);
        background: transparent;
      }

      .post-info {
        min-width: 0;
        display: flex;
        flex-direction: column;
        height: 100%;
      }

      .post-title-row {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 10px;
      }

      .post-title {
        font-size: 32px;
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -0.04em;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .badge.free {
        background: var(--free-bg);
        color: var(--free-text);
      }

      .badge.paid {
        background: var(--paid-bg);
        color: var(--paid-text);
      }

      .post-meta {
        color: var(--muted);
        font-size: 13px;
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 14px;
      }

      .post-excerpt {
        color: var(--muted);
        line-height: 1.85;
        font-size: 15px;
      }

      .post-card-actions {
        margin-top: auto;
        padding-top: 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .expand-tip {
        font-size: 13px;
        color: var(--accent);
        font-weight: 700;
      }

      .post-direct-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 34px;
        padding: 0 12px;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        background: var(--panel-strong);
        color: var(--text);
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        transition: transform 0.18s ease, background 0.18s ease, border-color 0.18s ease;
      }

      .post-direct-link:hover {
        transform: translateY(-1px);
        background: var(--accent-soft);
        border-color: var(--line-strong);
      }

      .post-body {
        text-align: justify;
        margin-top: 22px;
        padding: 26px 10px 8px;
        border-top: 1px solid var(--line);
      }

      .post-collapse-wrap {
        display: flex;
        justify-content: center;
        margin-top: 28px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
      }

      .post-collapse-btn {
        border: 0;
        background: transparent;
        color: var(--accent);
        font: inherit;
        font-size: 13px;
        font-weight: 700;
        cursor: pointer;
        padding: 6px 10px;
        border-radius: 999px;
        transition: background 0.18s ease, transform 0.18s ease, color 0.18s ease;
      }

      .post-collapse-btn:hover {
        background: var(--accent-soft);
        transform: translateY(-1px);
      }

      .prose {
        max-width: 72ch;
        font-size: 17px;
        line-height: 1.95;
      }

      .prose :global(h1),
      .prose :global(h2),
      .prose :global(h3),
      .prose :global(h4) {
        letter-spacing: -0.03em;
        line-height: 1.2;
        margin-top: 1.8em;
        margin-bottom: 0.7em;
      }

      .prose :global(h2) {
        font-size: 30px;
      }

      .prose :global(h3) {
        font-size: 24px;
      }

      .prose :global(p),
      .prose :global(li),
      .prose :global(blockquote) {
        color: var(--text);
      }

      .prose :global(p) {
        margin: 1em 0;
      }

      .prose :global(ul),
      .prose :global(ol) {
        padding-left: 1.4em;
      }

      .prose :global(blockquote) {
        margin: 1.4em 0;
        padding: 0.9em 1em;
        border-left: 3px solid var(--accent);
        background: var(--accent-soft);
        border-radius: 0 14px 14px 0;
      }

      .prose :global(img) {
        max-width: 100%;
        display: block;
        border-radius: 18px;
        margin: 22px 0;
      }

      .prose :global(a) {
        color: var(--accent);
      }

      .sidebar {
        position: sticky;
        top: 96px;
        border-radius: 24px;
        padding: 22px 18px;
      }

      .sidebar h3 {
        margin: 0 0 8px;
        font-size: 21px;
        letter-spacing: -0.03em;
      }

      .sidebar p {
        margin: 0 0 16px;
        color: var(--muted);
        line-height: 1.7;
        font-size: 14px;
      }

      .sidebar ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 10px;
      }

      .sidebar a {
        display: block;
        text-decoration: none;
        padding: 10px 12px;
        border-radius: 14px;
        border: 1px solid transparent;
        color: var(--text);
        font-size: 14px;
        line-height: 1.5;
        transition: background 0.18s ease, border-color 0.18s ease;
      }

      .sidebar a:hover {
        background: var(--accent-soft);
        border-color: var(--line);
      }

      .locked-box {
        max-width: 72ch;
        margin-top: 6px;
        padding: 20px 20px 18px;
        border-radius: 20px;
        background: var(--paid-bg);
        border: 1px solid rgba(255, 79, 216, 0.18);
      }

      .locked-box strong {
        display: block;
        margin-bottom: 8px;
        font-size: 16px;
      }

      .locked-box p {
        margin: 0;
        line-height: 1.85;
        color: var(--text);
      }

      .locked-actions {
        margin-top: 14px;
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0 16px;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        transition: transform 0.18s ease, box-shadow 0.18s ease;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button-primary {
        background: var(--text);
        color: var(--bg);
      }

      .button-primary:hover {
        box-shadow: 0 0 0 1px rgba(255, 79, 216, 0.18), 0 0 20px rgba(255, 79, 216, 0.12);
      }

      .button-secondary {
        border: 1px solid var(--line-strong);
        color: var(--text);
        background: var(--panel-strong);
      }

      .fi {
        border-radius: 2px;
        box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
        vertical-align: -1px;
      }

      @media (max-width: 1040px) {
        .layout {
          grid-template-columns: 1fr;
        }

        .sidebar {
          position: static;
        }
      }

      @media (max-width: 780px) {
        .container {
          padding: 18px 16px 68px;
        }

        .hero {
          padding: 24px 18px;
          border-radius: 24px;
        }

        .post-card,
        .sidebar {
          border-radius: 22px;
        }

        .post-header {
          grid-template-columns: 1fr;
        }

        .post-title {
          font-size: 28px;
        }

        .prose {
          font-size: 16px;
        }
      }
    </style>
  </Fragment>

  <div class="container">
    <section class="hero">
      <div class="hero-top">
        <div class="hero-copy">
          <span class="hero-kicker">国家/地区归档页</span>
          <h1>
            {countryCode ? (
              <span class={`fi fi-${countryCode.toLowerCase()}`}></span>
            ) : icon ? (
              <span>{icon}</span>
            ) : (
              <span>🌏</span>
            )}
            <span style="margin-left: 12px;">{countryName}</span>
          </h1>
          <p class="hero-subtitle">{countryDescription}</p>

          <div class="hero-stats">
            <span class="hero-stat">{region}</span>
            <span class="hero-stat">{countryPosts.length} 篇内容</span>
            <span class="hero-stat">{freeCount} 篇免费</span>
            <span class="hero-stat">{paidCount} 篇付费</span>
            <span class="hero-stat">
              {hasPaidAccess ? '会员访问已开启' : currentUser ? '当前账号未解锁付费内容' : '未登录'}
            </span>
          </div>
        </div>

        <div class="filter-bar">
          <button class="filter-btn active" data-filter="all" type="button">全部</button>
          <button class="filter-btn" data-filter="free" type="button">免费</button>
          <button class="filter-btn" data-filter="paid" type="button">付费</button>
        </div>
      </div>
    </section>

    <div class="layout">
      <main class="main-column">
        {renderedPosts.map(({ post, Content }) => (
          <details class="post-card" id={post.data.slug} data-tier={post.data.tier}>
            <summary class="post-summary">
              <div class="post-header">
                {post.data.cover ? (
                  <div class="post-cover">
                    <img src={post.data.cover} alt={post.data.title} loading="lazy" />
                  </div>
                ) : (
                  <div class="post-cover placeholder">暂无封面</div>
                )}

                <div class="post-info">
                  <div class="post-title-row">
                    <div class="post-title">{post.data.title}</div>
                    <span class={`badge ${post.data.tier}`}>
                      {post.data.tier === 'free' ? '免费' : '付费'}
                    </span>
                  </div>

                  <div class="post-meta">
                    {post.data.countryCode ? (
                      <span class={`fi fi-${post.data.countryCode.toLowerCase()}`}></span>
                    ) : post.data.icon ? (
                      <span>{post.data.icon}</span>
                    ) : (
                      <span>🌏</span>
                    )}
                    <span>{post.data.country} · {post.data.region}</span>
                    <span>·</span>
                    <span>
                      {`${new Date(post.data.date).getFullYear()}年${new Date(post.data.date).getMonth() + 1}月`}
                    </span>
                  </div>

                  <div class="post-excerpt">
                    {post.data.summary}
                  </div>

                  <div class="post-card-actions">
                    <span class="expand-tip">
                      点击展开阅读 {
                        post.data.tier === 'free'
                          ? '全文'
                          : hasPaidAccess
                            ? '全文'
                            : '摘要'
                      } ↓
                    </span>

                    <a
                      class="post-direct-link"
                      href={`/posts/${post.data.slug}`}
                      onclick="event.stopPropagation()"
                    >
                      独立阅读 →
                    </a>
                  </div>
                </div>
              </div>
            </summary>

            {post.data.tier === 'free' || hasPaidAccess ? (
              <div class="post-body">
                <article class="prose">
                  <Content />
                </article>

                <div class="post-collapse-wrap">
                  <button
                    type="button"
                    class="post-collapse-btn"
                    data-collapse-target={post.data.slug}
                  >
                    收起全文 ↑
                  </button>
                </div>
              </div>
            ) : (
              <div class="post-body">
                <div class="locked-box">
                  <strong>
                    {currentUser ? '当前内容需要有效会员权限' : '当前内容需要登录后查看会员状态'}
                  </strong>

                  <p>
                    {currentUser
                      ? '你已登录，但当前账号没有有效会员记录，暂时只能查看摘要。开通后将自动解锁完整正文。'
                      : '这篇内容属于付费内容。请先登录，再根据你的会员状态自动判断是否解锁。'}
                  </p>

                  <div class="locked-actions">
                    {!currentUser ? (
                      <a class="button button-primary" href="/login">登录后查看</a>
                    ) : (
                      <a class="button button-primary" href="/pricing">前往订阅</a>
                    )}
                    <a class="button button-secondary" href="/account">我的账户</a>
                  </div>

                  <div class="post-collapse-wrap">
                    <button
                      type="button"
                      class="post-collapse-btn"
                      data-collapse-target={post.data.slug}
                    >
                      收起摘要 ↑
                    </button>
                  </div>
                </div>
              </div>
            )}
          </details>
        ))}
      </main>

      <aside class="sidebar">
        <h3>本页目录</h3>
        <p>
          快速浏览当前国家下的全部内容。
        </p>

        <ul>
          {countryPosts.map((post) => (
            <li>
              
              <a href={`/posts/${post.data.slug}`}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </div>

  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      const buttons = document.querySelectorAll('.filter-btn');
      const cards = document.querySelectorAll('.post-card');
      const collapseButtons = document.querySelectorAll('.post-collapse-btn');

      const openCardFromHash = () => {
        const hash = window.location.hash.replace('#', '');
        if (!hash) return;

        const target = document.getElementById(hash);
        if (!target) return;

        target.setAttribute('open', '');

        requestAnimationFrame(() => {
          target.scrollIntoView({
            behavior: 'smooth',
            block: 'start',
          });
        });
      };

      openCardFromHash();

      window.addEventListener('hashchange', openCardFromHash);

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.getAttribute('data-filter');

          buttons.forEach((btn) => btn.classList.remove('active'));
          button.classList.add('active');

          cards.forEach((card) => {
            const tier = card.getAttribute('data-tier');

            if (filter === 'all' || tier === filter) {
              card.style.display = '';
            } else {
              card.style.display = 'none';
            }
          });
        });
      });

      collapseButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const targetId = button.getAttribute('data-collapse-target');
          if (!targetId) return;

          const card = document.getElementById(targetId);
          if (!card) return;

          card.removeAttribute('open');

          requestAnimationFrame(() => {
            card.scrollIntoView({
              behavior: 'smooth',
              block: 'start',
            });
          });
        });
      });
    });
  </script>
</BaseLayout>